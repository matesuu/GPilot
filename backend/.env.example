# Copy this file to .env and fill in your values.

# LLM API keys (provide at least one)
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=...

# Neo4j connection
NEO4J_URL=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j1234

# PolyG datasets root (directory containing physics/, goodreads/, amazon/)
POLYG_DATA_ROOT=/home/username/PolyG/datasets

# Default model used when the client doesn't specify one
POLYG_DEFAULT_MODEL=openai/gpt-4o-mini

# CORS — restrict to your frontend URL in production, e.g.:
# ALLOWED_ORIGINS=https://your-frontend.example.com
# Leave as * for local development
ALLOWED_ORIGINS=*
